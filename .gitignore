# Ignore virtual environment directories and configuration
venv/
pyvenv.cfg
data/pyvista_env/

# Ignore Python cache directories and compiled files
__pycache__/
*.py[cod]
*.pyo
*.so

# Ignore macOS metadata files
.DS_Store

# Ignore output and temporary files
output/
remote_results/

# Ignore private data
private/

# Ignore large Diviner data files (too big for remote)
global_cumul_avg_cyl_*.tab.txt

# Ignore profile outputs and debugging files
*.dot
*.prof
*.svg
*.gif

# Ignore archive and backup files
*.bak
*.swp
*.swo
*.tmp

# Ignore temporary files and artifacts from editors and IDEs
.vscode/
.idea/
*.iml
*.sublime-project
*.sublime-workspace

# Ignore environment and dependency files that are system-specific
*.env
*.virtualenv
*.tox/
node_modules/
build/
dist/

# Ignore any large datasets or generated CSVs that might clutter the repo
*.csv
*.npz
*.png
*.h5

# Local generated files
.requirements_hash
.venv_initialized
.direnv/

# Ignore auto-generated config files
data/config/*_TI_*.yaml
data/config/optimiser_runs/

# Ignore DGL_KS comparison files
DGL_KS_comparison/
DGL_KS_comparison_outputs/

# Ignore deprecated TEMPEST_RAD scripts and files
TEMPEST_RAD/deprecated/

# Ignore ROI backup notebook
notebooks/region_of_interest_analysis_backup.ipynb

# Ignore macOS Finder duplicate files
*\ 2.*
*\ 2
